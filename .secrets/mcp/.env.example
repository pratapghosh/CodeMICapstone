# MCP shared secrets template
# Copy values into .secrets/mcp/.env and replace placeholders.

# Jira MCP
JIRA_INSTANCE_URL=https://your-instance.atlassian.net
JIRA_USER_EMAIL=your-email@company.com
JIRA_API_KEY=replace-with-your-token

# GitLab MCP
GITLAB_PERSONAL_ACCESS_TOKEN=replace-with-your-gitlab-pat
# For self-hosted GitLab: must include /api/v4
GITLAB_API_URL=https://your-gitlab-instance.com/api/v4
